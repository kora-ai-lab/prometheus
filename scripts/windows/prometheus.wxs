<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" 
           Name="Prometheus" 
           Language="1033" 
           Version="1.0.5.0" 
           Manufacturer="kora-ai-lab" 
           UpgradeCode="YOUR-GUID-HERE">
    
    <Package InstallerVersion="200" 
             Compressed="yes" 
             InstallScope="perMachine" 
             Platform="x64" />
    
    <MajorUpgrade DowngradeErrorMessage="A newer version of Prometheus is already installed." />
    
    <MediaTemplate EmbedCab="yes" />
    
    <Feature Id="ProductFeature" Title="Prometheus" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="PathEnvironmentVariable" />
    </Feature>
    
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Prometheus">
          <Component Id="MainExecutable" Guid="*">
            <File Id="ExeFile" Source="prometheus-windows-amd64.exe" KeyPath="yes">
              <Shortcut Id="DesktopShortcut" Directory="DesktopFolder" Name="Prometheus" Icon="PrometheusIcon.exe" IconIndex="0" Advertise="yes" />
              <Shortcut Id="StartMenuShortcut" Directory="ProgramMenuFolder" Name="Prometheus" Icon="PrometheusIcon.exe" IconIndex="0" Advertise="yes" />
            </File>
          </Component>
        </Directory>
      </Directory>
      
      <Directory Id="ProgramMenuFolder" Name="Programs">
        <Directory Id="ProgramMenuSubfolder" Name="Prometheus">
          <Component Id="StartMenuShortcuts" Guid="*">
            <Shortcut Id="UninstallShortcut" Name="Uninstall Prometheus" Target="[System64Folder]msiexec.exe" Arguments="/x [ProductCode]" Description="Uninstall Prometheus" />
            <RemoveFolder Id="ProgramMenuSubfolder" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\kora-ai-lab\Prometheus" Name="installed" Type="integer" Value="1" KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
      
      <Directory Id="DesktopFolder" Name="Desktop" />
    </Directory>
    
    <Component Id="PathEnvironmentVariable" Guid="*" Directory="INSTALLFOLDER">
      <Environment Id="PATH" Name="PATH" Value="[INSTALLFOLDER]" Permanent="no" Part="last" Action="set" System="yes" />
    </Component>
    
    <Icon Id="PrometheusIcon.exe" SourceFile="prometheus-windows-amd64.exe" />
  </Product>
</Wix>
